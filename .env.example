# ============================================================
#   ASISTENTE TRADING — Variables de entorno
#   Copia este archivo como ".env" y rellena los valores
#   NUNCA subas el archivo .env a GitHub
# ============================================================

# === EXCHANGE (Binance) ===
# Obtén las claves en: binance.com > API Management
EXCHANGE_API_KEY=pega_tu_api_key_aqui
EXCHANGE_API_SECRET=pega_tu_api_secret_aqui
EXCHANGE_TESTNET=true

# === TELEGRAM ===
# Crea un bot en Telegram hablando con @BotFather
# Obtén tu chat_id hablando con @userinfobot
TELEGRAM_TOKEN=pega_el_token_del_bot_aqui
TELEGRAM_CHAT_ID=pega_tu_chat_id_aqui
TELEGRAM_ENABLED=false

# === TRADING (opcional, sobreescribe settings.yaml) ===
TRADING_MODE=paper
TRADING_CAPITAL=1000
